# ============================================================
# DevisTerrazzo — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Prix Stripe (créer dans le dashboard Stripe)
STRIPE_PRICE_STARTER=price_xxx   # 15€/lead
STRIPE_PRICE_PRO=price_xxx       # 35€/lead
STRIPE_PRICE_EXCLUSIF=price_xxx  # 60€/lead

# Abonnements mensuels Stripe
STRIPE_SUBSCRIPTION_PRO=price_xxx       # Pro 5 leads/mois = 175€
STRIPE_SUBSCRIPTION_EXCLUSIF=price_xxx  # Exclusif 1 lead/mois = 60€

# --- Resend (Emails) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@devis-terrazzo.fr
RESEND_FROM_NAME=DevisTerrazzo

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+33xxxxxxxxx

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SECRET_KEY=changeme_super_secret_key_admin
JWT_SECRET=changeme_jwt_secret_for_artisan_sessions

# --- Email Admin ---
ADMIN_EMAIL=admin@devis-terrazzo.fr
